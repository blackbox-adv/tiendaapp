generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---- TiendApp SaaS Models ----
// Supabase PostgreSQL - ensure DATABASE_URL points to your Supabase project

model Plan {
  id          String   @id @default(cuid())
  type        String   @unique                    // free, pro, premium
  name        String
  price       Decimal  @default(0) @db.Decimal(10,2)   // FIXED: Float → Decimal for monetary values
  currency    String   @default("PEN")
  maxProducts Int      @default(10)
  description String   @default("")
  features    Json     @default("[]")              // FIXED: String → Json for structured data
  popular     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
  payments     Payment[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String                                // bcrypt hash
  name      String
  role      String   @default("store_owner")      // super_admin, store_owner
  phone     String?
  avatar    String?
  isActive          Boolean  @default(true)
  lastLogin         DateTime?
  resetToken        String?
  resetTokenExpires DateTime?
  tokenVersion      Int      @default(0)          // For JWT invalidation on password change
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  stores       Store[]
  subscriptions Subscription[]
  payments     Payment[]
  sentNotifications Notification[] @relation("SentNotifications")

  @@index([role])                                 // For admin queries
  @@index([isActive])                             // For filtering active users
  @@index([createdAt])                            // For sorting newest users
  @@index([resetToken])                           // For password reset lookup
}

model Store {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String   @default("")
  logo           String   @default("")
  primaryColor   String   @default("#7C3AED")
  secondaryColor String   @default("#10B981")
  whatsappNumber String?
  template       String   @default("moderna")     // moderna, vibrante, clasica, luxury, minimalist
  bannerUrl      String   @default("")
  category       String   @default("otros")
  hasShipping      Boolean  @default(false)
  hasSecurePayment Boolean  @default(false)
  hasReturns       Boolean  @default(false)

  // Promo Popup configuration
  popupEnabled     Boolean  @default(false)
  popupType        String   @default("product")    // "product" (Pro) or "custom" (Premium)
  popupProductId   String?                           // Product ID to feature (Pro plan)
  popupCustomImage String?                           // Custom uploaded promo image (Premium plan)
  popupTitle       String?                           // e.g. "2x1 solo este mes"
  popupButtonText  String   @default("Ver oferta")  // CTA button text

  isActive       Boolean  @default(true)
  visitCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  products      StoreProduct[]
  subscriptions Subscription[]
  payments     Payment[]

  @@index([ownerId])                              // Owner's stores lookup
  @@index([isActive])                             // Active stores filter
  @@index([category])                             // Category browse
  @@index([visitCount(sort: Desc)])               // Popular stores
  @@index([createdAt(sort: Desc)])                // Newest stores
}

model StoreProduct {
  id            String   @id @default(cuid())
  name          String
  description   String   @default("")
  price         Decimal  @db.Decimal(10,2)        // FIXED: Float → Decimal for monetary values
  originalPrice Decimal? @db.Decimal(10,2)        // FIXED: Float → Decimal for monetary values
  imageUrl      String   @default("")
  category      String   @default("")
  color         String?
  isActive      Boolean  @default(true)
  featured      Boolean  @default(false)
  rating        Decimal  @default(0) @db.Decimal(2,1) // FIXED: Float → Decimal with 1 decimal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])                              // Products by store
  @@index([storeId, isActive])                    // Active products per store
  @@index([storeId, featured(sort: Desc)])        // Featured products per store
  @@index([createdAt(sort: Desc)])                // Newest products
  @@index([category])                             // Products by category
}

model Subscription {
  id              String    @id @default(cuid())
  status          String    @default("active")    // active, past_due, cancelled, expired
  startDate       DateTime  @default(now())
  endDate         DateTime?                      // Set when cancelled or expired
  nextBillingDate DateTime?                      // When the next payment is due
  billingCycle    String    @default("monthly")  // monthly, yearly
  amountPaid      Decimal   @default(0) @db.Decimal(10,2) // FIXED: Float → Decimal

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  storeId String
  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan @relation(fields: [planId], references: [id], onDelete: Restrict)

  payments Payment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])                               // User's subscriptions
  @@index([storeId])                              // Store's subscriptions
  @@index([status])                               // Active subscriptions filter
  @@index([status, nextBillingDate])              // Billing check queries
  @@index([userId, storeId])                      // Composite lookup for ownership checks
  @@index([userId, storeId, status])              // Active subscription per user+store query
  // REMOVED: @@unique([userId, storeId, status]) — broken on re-subscription
  // Instead, enforce one active subscription per user+store at application level
}

model Payment {
  id              String   @id @default(cuid())
  amount          Decimal  @db.Decimal(10,2)      // FIXED: Float → Decimal for monetary values
  currency        String   @default("PEN")
  status          String   @default("pending")   // pending, completed, failed, rejected, refunded
  paymentMethod   String?                        // culqi, niubiz, bank_transfer, yape, plin
  externalRef     String?                        // Reference from payment gateway
  gatewayResponse String?                        // Full gateway response (JSON string)
  receiptUrl      String?                        // URL to payment receipt/voucher image
  verifiedAt      DateTime?                      // When admin verified the payment
  verifiedBy      String?                        // Admin user ID who verified
  notes           String?                        // Admin notes on this payment
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: SetNull)

  storeId String
  store   Store @relation(fields: [storeId], references: [id], onDelete: SetNull)

  planId String
  plan   Plan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])                               // User's payments
  @@index([storeId])                              // Store's payments
  @@index([status])                               // Payment status filter
  @@index([createdAt(sort: Desc)])                // Recent payments
  @@index([externalRef])                          // Gateway reference lookup & idempotency
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String                             // LOGIN_SUCCESS, PAYMENT_APPROVED, etc.
  userId     String?
  userEmail  String?
  ip         String?
  details    Json?                              // Structured details
  success    Boolean  @default(true)
  statusCode Int?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@index([key])                                  // Settings lookup
}

model Notification {
  id         String   @id @default(cuid())
  title      String
  message    String
  type       String   @default("info")            // info, success, warning, promo, system
  icon       String   @default("bell")             // Emoji or icon name
  link       String?                              // Optional navigation link
  userId     String?                              // null = broadcast (all users)
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Who sent it (admin)
  senderId   String?
  sender     User?    @relation("SentNotifications", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([userId, read])                         // Unread count per user
  @@index([userId, createdAt(sort: Desc)])        // User's notifications sorted by date
  @@index([createdAt(sort: Desc)])                // Global sorted list
  @@index([type])                                 // Filter by type
}
